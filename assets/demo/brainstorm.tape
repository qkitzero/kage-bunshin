# kage-bunshin /brainstorm demo
# Run from repo root: vhs assets/demo/brainstorm.tape
# Output script: assets/demo/run.sh

Output assets/demo/brainstorm.gif

Set Shell "zsh"
Set FontSize 20
Set Width 1200
Set Height 720
Set Theme "tokyonight"
Set TypingSpeed 40ms

Hide
Type "clear"
Enter
Sleep 500ms
Type "bash assets/demo/run.sh"
Enter
Show

Sleep 20s
